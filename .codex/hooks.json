{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "bd codex-hook PostCompact",
            "statusMessage": "Scheduling Beads context refresh",
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd codex-hook PreCompact",
            "statusMessage": "Checking Beads context",
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/agent-boundary-guard.sh\"",
            "type": "command"
          }
        ],
        "matcher": "^Bash$"
      },
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/worktree-guard.sh\"",
            "type": "command"
          }
        ],
        "matcher": "^(Bash|apply_patch)$"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd codex-hook SessionStart",
            "statusMessage": "Loading Beads context",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      },
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/koryph-prime.sh\"  # replaces: bd prime --hook-json",
            "type": "command"
          }
        ],
        "matcher": "^(startup|resume|clear)$"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bd codex-hook UserPromptSubmit",
            "statusMessage": "Refreshing Beads context",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/koryph-intent.sh\"",
            "type": "command"
          }
        ]
      }
    ]
  }
}
