{
  "_rationale": "Requires at least one reviewer and optional required CI status checks before any change can merge to the default branch.",
  "_rule_descriptions": {
    "pull_request": "Requires at least one human review before a PR can merge, preventing unreviewed code from landing on the default branch.",
    "required_status_checks": "Blocks merging until the named CI checks all pass, preventing broken or untested code from landing on the default branch."
  },
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "~DEFAULT_BRANCH"
      ]
    }
  },
  "enforcement": "active",
  "name": "pr-checks",
  "rules": [
    {
      "parameters": {
        "allowed_merge_methods": [
          "merge",
          "squash",
          "rebase"
        ],
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_approving_review_count": 1,
        "required_review_thread_resolution": false,
        "required_reviewers": []
      },
      "type": "pull_request"
    }{{if .RequiredChecks}},
    {
      "parameters": {
        "do_not_enforce_on_create": false,
        "required_status_checks": {{toJSON .RequiredChecks}},
        "strict_required_status_checks_policy": true
      },
      "type": "required_status_checks"
    }{{end}}
  ],
  "target": "branch"
}
