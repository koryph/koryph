# Generated by `koryph release setup`. Do not edit by hand; re-run the command
# to update. The image is pushed by digest before mutable tags are promoted.
name: container-release
on:
  push:
    branches: [main]
permissions:
  contents: read
  packages: write
  id-token: write
  attestations: write
env:
  REGISTRY: {{.Registry}}
  IMAGE: {{.Image}}
jobs:
  detect-release:
    name: detect release merge
    runs-on: ubuntu-latest
    outputs:
      release: ${{"{{"}} steps.detect.outputs.release }}
      version: ${{"{{"}} steps.detect.outputs.version }}
    steps:
      - uses: actions/checkout@3d3c42e5aac5ba805825da76410c181273ba90b1 # v7.0.1
        with:
          fetch-depth: 1
      - name: Detect a release-PR merge
        id: detect
        run: |
          subject="$(git log -1 --format=%s)"
          if [[ "$subject" =~ ^chore\(main\):\ release\ ([0-9]+\.[0-9]+\.[0-9]+) ]]; then
            echo "release=true" >> "$GITHUB_OUTPUT"
            echo "version=${BASH_REMATCH[1]}" >> "$GITHUB_OUTPUT"
          else
            echo "release=false" >> "$GITHUB_OUTPUT"
          fi
  publish:
    name: build, sign, and attest image
    runs-on: ubuntu-latest
    needs: detect-release
    if: ${{"{{"}} needs.detect-release.outputs.release == 'true' }}
    steps:
      - uses: actions/checkout@3d3c42e5aac5ba805825da76410c181273ba90b1 # v7.0.1
      - uses: docker/setup-buildx-action@8d2750c68a42422c14e847fe6c8ac0403b4cbd6f # v3.12.0
      - uses: docker/login-action@74a5d142397b4f367a81961eba4e8cd7edddf772 # v3.4.0
        with:
          registry: ${{"{{"}} env.REGISTRY }}
          username: ${{"{{"}} github.actor }}
          password: ${{"{{"}} secrets.GITHUB_TOKEN }}
      - name: Resolve image tags
        id: meta
        uses: docker/metadata-action@902fa8ec7d6ecbf8d84d538b9b233a880e428804 # v5.7.0
        with:
          images: ${{"{{"}} env.REGISTRY }}/${{"{{"}} env.IMAGE }}
          tags: |
            type=raw,value=v${{"{{"}} needs.detect-release.outputs.version }}
      - name: Build and push image by digest
        id: build
        uses: docker/build-push-action@263435318d21b8e681c14492fe198d362a7d2c83 # v6.18.0
        with:
          context: .
          push: true
          labels: ${{"{{"}} steps.meta.outputs.labels }}
          outputs: type=image,name=${{"{{"}} env.REGISTRY }}/${{"{{"}} env.IMAGE }},push-by-digest=true,name-canonical=true,push=true
      - name: Promote tags from the pushed digest
        env:
          DIGEST: ${{"{{"}} steps.build.outputs.digest }}
          TAGS: ${{"{{"}} steps.meta.outputs.tags }}
        run: |
          set -euo pipefail
          args=()
          while IFS= read -r tag; do
            [ -n "$tag" ] && args+=(--tag "$tag")
          done <<< "$TAGS"
          docker buildx imagetools create "${args[@]}" "$REGISTRY/$IMAGE@$DIGEST"
      - uses: sigstore/cosign-installer@6f9f17788090df1f26f669e9d70d6ae9567deba6 # v4.1.2
      - name: Sign the immutable image digest
        env:
          DIGEST: ${{"{{"}} steps.build.outputs.digest }}
        run: cosign sign --yes "$REGISTRY/$IMAGE@$DIGEST"
      - uses: anchore/sbom-action/download-syft@e22c389904149dbc22b58101806040fa8d37a610 # v0.24.0
      - name: Generate and attach the SPDX SBOM
        env:
          DIGEST: ${{"{{"}} steps.build.outputs.digest }}
        run: |
          set -euo pipefail
          syft "$REGISTRY/$IMAGE@$DIGEST" --output spdx-json=image.sbom.spdx.json
          cosign attest --yes --type spdxjson --predicate image.sbom.spdx.json "$REGISTRY/$IMAGE@$DIGEST"
      - name: Attest build provenance for the image digest
        uses: actions/attest-build-provenance@db473fddc028af60658334401dc6fa3ffd8669fd # v2.3.0
        with:
          subject-name: ${{"{{"}} env.REGISTRY }}/${{"{{"}} env.IMAGE }}
          subject-digest: ${{"{{"}} steps.build.outputs.digest }}
          push-to-registry: true
