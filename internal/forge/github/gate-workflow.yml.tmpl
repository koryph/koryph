# Generated by `koryph ci setup --kind gate`. Do not edit by hand; re-run the
# command to update.
#
# Green gate workflow — runs the project's gate command on every push and
# every pull request. Keeps the default branch and all open PRs green.
#
# Gate command: {{ .GateCmd }}
# Override with `koryph ci setup --kind gate --gate-cmd <cmd>` and re-run.
#
# This workflow is toolchain-neutral: it checks out the repository and runs
# the gate command as given; no language runtime is installed here. Add a
# setup step (e.g. actions/setup-go) to your project's workflow if your gate
# command requires one.
name: gate
on:
  push:
  pull_request:
permissions:
  contents: read
jobs:
  gate:
    name: gate
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Run gate
        run: {{ .GateCmd }}
