# Generated by `koryph release setup`. Do not edit by hand; re-run the
# command to update.
#
# koryph release train for GitLab — conventional-commit release pipeline.
#
# Pipeline kinds (selected by workflow.rules via $PIPELINE_KIND):
#   upkeep  — push to main that is NOT a release merge commit.
#             Scans conventional commits since the last semver tag, computes
#             the next version, then creates or updates a Release MR authored
#             by the project access token ($KORYPH_RELEASE_TOKEN). GitLab
#             pipelines run for bot-authored MRs by default — no close/reopen
#             trap that GitHub bots face.
#   release — merge commit whose title matches /^chore\(release\): v/.
#             Extracts the version, pushes a signed git tag, builds artifacts,
#             uploads them to the generic package registry, signs the checksum
#             manifest with cosign keyless OIDC, then creates the GitLab
#             Release with asset links as the final step.
#   mr      — any MR source-branch pipeline. Gate jobs run here.
#
# Assemble-then-create invariant (Capabilities.DraftReleases == false):
#   All binary artifacts land in the generic package registry BEFORE the
#   Release object is created. Nothing is user-visible until the
#   release-create job completes successfully. This maps to the same
#   "nothing published until everything is attached" invariant that GitHub's
#   draft-release/publish strategy provides, using different mechanics.
#
# Signing — cosign keyless via GitLab CI OIDC id_tokens:
#   The sign job requests a short-lived OIDC token (audience: sigstore) and
#   passes it to `cosign sign-blob`. Verification uses the GitLab OIDC issuer
#   and the pipeline's subject claim. Requires cosign v2.2+ and GitLab 15.7+.
#
# Required CI/CD variables (set in project Settings → CI/CD → Variables):
#   KORYPH_RELEASE_TOKEN — project or group access token with api + write_repository
#                          scopes; used to push the release branch, create the
#                          Release MR, and push the semver tag. The CI_JOB_TOKEN
#                          cannot push branches or tags in most project configs.
#
# SLSA gap (honest capability statement):
#   The SLSA GitHub Generator is GitHub-specific and is NOT available on
#   GitLab. Cosign keyless signing provides artifact authenticity and a
#   verifiable build identity (GitLab CI OIDC subject), but this does NOT
#   constitute SLSA Build Level 3 provenance. GitLab 16.1+ artifact
#   attestations (--attest flag on job artifacts) provide a lighter in-toto
#   record; enabling them is noted in the sign job comment below. Projects
#   requiring SLSA L3 should use the GitHub forge or supplement with a
#   custom in-toto signing step.

# ---------------------------------------------------------------------------
# Workflow rules: select pipeline kind
# ---------------------------------------------------------------------------

workflow:
  rules:
    # Release MR merge commit → full release pipeline
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH && $CI_COMMIT_TITLE =~ /^chore\(release\): v/'
      variables:
        PIPELINE_KIND: release
    # Any MR source-branch pipeline → gate (lint / test)
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
      variables:
        PIPELINE_KIND: mr
    # Ordinary push to default branch → Release MR upkeep
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
      variables:
        PIPELINE_KIND: upkeep
    # Everything else: skip (feature branches, tags not from this pipeline, …)
    - when: never

# ---------------------------------------------------------------------------
# Global variables (override in project CI/CD variables as needed)
# ---------------------------------------------------------------------------

variables:
  ARTIFACTS_DIR: "{{.ArtifactsDir}}"
  RELEASE_MR_LABEL: koryph-release
  RELEASE_BRANCH_PREFIX: release/koryph

# ---------------------------------------------------------------------------
# Stages
# ---------------------------------------------------------------------------

stages:
  - prepare   # upkeep: compute version + Release MR | release: tag
  - build     # release: build artifacts
  - sign      # release: cosign keyless
  - publish   # release: upload to generic registry + create Release

# ===========================================================================
# UPKEEP PIPELINE — create / update Release MR
# ===========================================================================

# compute-version: scan conventional commits since the last semver tag and
# determine the next version. Outputs NEXT_VERSION via dotenv artifact.
#
# Version bump rules (conventional commits):
#   BREAKING CHANGE footer or "type!" prefix → bump MAJOR (reset MINOR, PATCH)
#   feat                                     → bump MINOR (reset PATCH)
#   fix | perf | refactor                    → bump PATCH
#   Any other type (docs, chore, ci, …)      → no release; exit clean
compute-version:
  stage: prepare
  image: alpine/git:2
  rules:
    - if: '$PIPELINE_KIND == "upkeep"'
  variables:
    GIT_DEPTH: 0   # full history required for tag detection
  script:
    - |
      # ── locate the last semver tag ──────────────────────────────────────
      LAST_TAG=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1)
      LAST_TAG=${LAST_TAG:-v0.0.0}
      echo "compute-version: last tag = ${LAST_TAG}"

      V=${LAST_TAG#v}
      MAJOR=$(echo "$V" | cut -d. -f1)
      MINOR=$(echo "$V" | cut -d. -f2)
      PATCH=$(echo "$V" | cut -d. -f3)

      # ── read commit log since last tag (subject + body) ─────────────────
      LOG=$(git log "${LAST_TAG}..HEAD" --format="%s%n%b" 2>/dev/null)

      # ── compute bump ────────────────────────────────────────────────────
      if echo "$LOG" | grep -qE "^BREAKING CHANGE:|^[a-z]+(\(.+\))?!:"; then
        NEXT="v$((MAJOR + 1)).0.0"
      elif echo "$LOG" | grep -qE "^feat(\(.+\))?:"; then
        NEXT="v${MAJOR}.$((MINOR + 1)).0"
      elif echo "$LOG" | grep -qE "^(fix|perf|refactor)(\(.+\))?:"; then
        NEXT="v${MAJOR}.${MINOR}.$((PATCH + 1))"
      else
        echo "compute-version: no releasable commits since ${LAST_TAG} — skipping."
        echo "NEXT_VERSION=" > version.env
        exit 0
      fi

      echo "compute-version: next = ${NEXT}"
      echo "NEXT_VERSION=${NEXT}" > version.env
  artifacts:
    reports:
      dotenv: version.env

# release-mr: create or update the Release MR for the computed next version.
# Opens the MR against the default branch using the project access token
# ($KORYPH_RELEASE_TOKEN) so that CI/CD pipelines fire on the MR without
# the close/reopen workaround needed on GitHub.
release-mr:
  stage: prepare
  image: alpine/git:2
  rules:
    - if: '$PIPELINE_KIND == "upkeep"'
  needs:
    - job: compute-version
      artifacts: true
  variables:
    GIT_DEPTH: 0
  script:
    - |
      if [ -z "${NEXT_VERSION}" ]; then
        echo "release-mr: no next version — nothing to do."
        exit 0
      fi

      # ── install curl + jq ───────────────────────────────────────────────
      apk add --no-cache curl jq > /dev/null 2>&1

      API="${CI_API_V4_URL}/projects/${CI_PROJECT_ID}"
      RELEASE_BRANCH="${RELEASE_BRANCH_PREFIX}-${NEXT_VERSION}"
      MR_TITLE="chore(release): ${NEXT_VERSION}"

      # ── generate changelog section ───────────────────────────────────────
      LAST_TAG=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || echo "v0.0.0")
      FEATS=$(git log "${LAST_TAG}..HEAD" --format="* %s" 2>/dev/null | grep -E '^\* feat' || true)
      FIXES=$(git log "${LAST_TAG}..HEAD" --format="* %s" 2>/dev/null | grep -E '^\* fix' || true)
      BREAKS=$(git log "${LAST_TAG}..HEAD" --format="* %s%n%b" 2>/dev/null | grep -E '^(BREAKING CHANGE:|.+!:)' || true)

      MR_BODY="## ${NEXT_VERSION}"
      [ -n "$BREAKS" ] && MR_BODY="${MR_BODY}\n\n### ⚠ Breaking Changes\n${BREAKS}"
      [ -n "$FEATS" ]  && MR_BODY="${MR_BODY}\n\n### Features\n${FEATS}"
      [ -n "$FIXES" ]  && MR_BODY="${MR_BODY}\n\n### Bug Fixes\n${FIXES}"
      MR_BODY="${MR_BODY}\n\n---\n*Release MR generated by koryph release train. Merge to publish ${NEXT_VERSION}.*"

      # ── check for an existing open Release MR ───────────────────────────
      EXISTING_IID=$(curl -sf \
        --header "PRIVATE-TOKEN: ${KORYPH_RELEASE_TOKEN}" \
        "${API}/merge_requests?state=opened&labels=${RELEASE_MR_LABEL}&per_page=1" \
        | jq -r '.[0].iid // empty')

      # ── configure git identity ───────────────────────────────────────────
      git config user.email "koryph-bot@${CI_SERVER_HOST}"
      git config user.name "koryph release bot"

      # ── push release branch ──────────────────────────────────────────────
      PUSH_URL="https://koryph-bot:${KORYPH_RELEASE_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git"
      git checkout -B "${RELEASE_BRANCH}"
      git commit --allow-empty -s -m "${MR_TITLE}"
      git push "${PUSH_URL}" "HEAD:${RELEASE_BRANCH}" --force

      # ── create or update the Release MR ─────────────────────────────────
      if [ -n "${EXISTING_IID}" ]; then
        curl -sf --request PUT \
          --header "PRIVATE-TOKEN: ${KORYPH_RELEASE_TOKEN}" \
          --header "Content-Type: application/json" \
          --data "$(jq -n --arg t "${MR_TITLE}" --arg b "$(printf '%b' "${MR_BODY}")" \
            '{title: $t, description: $b}')" \
          "${API}/merge_requests/${EXISTING_IID}" > /dev/null
        echo "release-mr: updated Release MR !${EXISTING_IID} → ${NEXT_VERSION}"
      else
        curl -sf --request POST \
          --header "PRIVATE-TOKEN: ${KORYPH_RELEASE_TOKEN}" \
          --header "Content-Type: application/json" \
          --data "$(jq -n \
            --arg src "${RELEASE_BRANCH}" \
            --arg tgt "${CI_DEFAULT_BRANCH}" \
            --arg t "${MR_TITLE}" \
            --arg b "$(printf '%b' "${MR_BODY}")" \
            --arg lbl "${RELEASE_MR_LABEL}" \
            '{source_branch: $src, target_branch: $tgt, title: $t, description: $b,
              labels: $lbl, squash: true, remove_source_branch: true}')" \
          "${API}/merge_requests" > /dev/null
        echo "release-mr: created Release MR for ${NEXT_VERSION}"
      fi

# ===========================================================================
# RELEASE PIPELINE — tag → build → sign → upload → release-create
# ===========================================================================

# tag-release: parse the version from the merge commit title, push a signed
# annotated tag via the project access token.
# NOTE: the tag push MUST use KORYPH_RELEASE_TOKEN (not CI_JOB_TOKEN) so that
# GitLab does not block the tag-triggered downstream pipelines.
tag-release:
  stage: prepare
  image: alpine/git:2
  rules:
    - if: '$PIPELINE_KIND == "release"'
  variables:
    GIT_DEPTH: 0
  script:
    - |
      RELEASE_TAG=$(echo "${CI_COMMIT_TITLE}" | sed -n 's/^chore(release): \(v[0-9][^ ]*\)$/\1/p')
      if [ -z "${RELEASE_TAG}" ]; then
        echo "tag-release: ERROR: cannot parse version from: ${CI_COMMIT_TITLE}"
        exit 1
      fi

      echo "tag-release: pushing ${RELEASE_TAG}"
      git config user.email "koryph-bot@${CI_SERVER_HOST}"
      git config user.name "koryph release bot"
      git tag -a "${RELEASE_TAG}" -m "Release ${RELEASE_TAG}" "${CI_COMMIT_SHA}"
      git push \
        "https://koryph-bot:${KORYPH_RELEASE_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git" \
        "refs/tags/${RELEASE_TAG}"

      echo "RELEASE_TAG=${RELEASE_TAG}" > tag.env
  artifacts:
    reports:
      dotenv: tag.env

# ---------------------------------------------------------------------------
# Build stage
# ---------------------------------------------------------------------------
{{if eq .BuildMode "goreleaser"}}
# build: run GoReleaser to cross-compile and create release archives.
# --skip=publish stops GoReleaser from creating the GitLab Release itself;
# the release-create job does that as the final step (assemble-then-create).
# GoReleaser's .goreleaser.yaml must include `gitlab_urls` so that it
# resolves the GitLab API and formats archive names correctly.
build:
  stage: build
  image: goreleaser/goreleaser:{{.GoreleaserVersion}}
  rules:
    - if: '$PIPELINE_KIND == "release"'
  needs:
    - job: tag-release
      artifacts: true
  script:
    - goreleaser release --skip=publish --clean
  artifacts:
    paths:
      - "{{.ArtifactsDir}}/"
    expire_in: 1 hour
  variables:
    GITLAB_TOKEN: "${KORYPH_RELEASE_TOKEN}"
    CI_JOB_TOKEN: "${CI_JOB_TOKEN}"
{{else}}
# build: run project build commands and populate ARTIFACTS_DIR.
# Commands must produce a checksums.txt (or one is generated automatically).
build:
  stage: build
  rules:
    - if: '$PIPELINE_KIND == "release"'
  needs:
    - job: tag-release
      artifacts: true
  script:{{range .BuildCommands}}
    - {{.}}{{end}}
    - |
      # Generate checksums.txt if the build did not produce one.
      if [ ! -f "${ARTIFACTS_DIR}/checksums.txt" ]; then
        (cd "${ARTIFACTS_DIR}" && sha256sum ./* > checksums.txt)
      fi
  artifacts:
    paths:
      - "${ARTIFACTS_DIR}/"
    expire_in: 1 hour
{{end}}
# ---------------------------------------------------------------------------
# Sign stage — cosign keyless via GitLab CI OIDC id_tokens
# ---------------------------------------------------------------------------
#
# GitLab 15.7+ is required for id_tokens. The SIGSTORE_ID_TOKEN is a
# short-lived OIDC JWT projected by GitLab CI with the sigstore audience.
#
# Verification command (run locally after the release):
#   cosign verify-blob \
#     --certificate-identity \
#       "https://gitlab.com/${CI_PROJECT_PATH}//.gitlab-ci.yml@refs/heads/main" \
#     --certificate-oidc-issuer "https://gitlab.com" \
#     --bundle dist/checksums.txt.bundle \
#     dist/checksums.txt
#
# SLSA gap: cosign keyless signing provides artifact authenticity and a
# verifiable build identity. It does NOT constitute SLSA Build Level 3
# provenance. GitLab 16.1+ artifact attestations (--attest flag) produce
# an in-toto record for individual artifacts; they are not enabled here but
# can be added to the build job artifacts stanza if needed.
sign:
  stage: sign
  image: bitnami/cosign:latest
  rules:
    - if: '$PIPELINE_KIND == "release"'
  needs:
    - job: build
      artifacts: true
    - job: tag-release
      artifacts: true
  id_tokens:
    SIGSTORE_ID_TOKEN:
      aud: sigstore
  script:
    - |
      CHECKSUM_FILE="${ARTIFACTS_DIR}/checksums.txt"
      if [ ! -f "${CHECKSUM_FILE}" ]; then
        echo "sign: ERROR: ${CHECKSUM_FILE} not found"
        exit 1
      fi
      cosign sign-blob \
        --yes \
        --bundle "${CHECKSUM_FILE}.bundle" \
        --identity-token "${SIGSTORE_ID_TOKEN}" \
        "${CHECKSUM_FILE}"
      echo "sign: signed ${CHECKSUM_FILE}"
  artifacts:
    paths:
      - "{{.ArtifactsDir}}/checksums.txt.bundle"
    expire_in: 1 hour

# ---------------------------------------------------------------------------
# Publish stage — upload to generic registry, then create Release
# ---------------------------------------------------------------------------

# upload-packages: push all artifacts from ARTIFACTS_DIR to the GitLab
# generic package registry. The release-create job then links them in the
# Release object, implementing the assemble-then-create invariant:
# assets exist in the registry but are invisible to end-users until the
# Release is created in the next job.
upload-packages:
  stage: publish
  image: alpine/curl:latest
  rules:
    - if: '$PIPELINE_KIND == "release"'
  needs:
    - job: sign
      artifacts: true
    - job: build
      artifacts: true
    - job: tag-release
      artifacts: true
  script:
    - |
      apk add --no-cache curl > /dev/null 2>&1
      PKG_URL="${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/generic/${CI_PROJECT_NAME}/${RELEASE_TAG}"
      echo "upload-packages: uploading artifacts to ${PKG_URL}"

      UPLOADED=""
      for f in ${ARTIFACTS_DIR}/*; do
        [ -f "$f" ] || continue
        FNAME=$(basename "$f")
        curl -sf --header "PRIVATE-TOKEN: ${KORYPH_RELEASE_TOKEN}" \
          --upload-file "$f" "${PKG_URL}/${FNAME}"
        echo "upload-packages: ✓ ${FNAME}"
        LINK="${CI_SERVER_URL}/${CI_PROJECT_PATH}/-/package_files/${CI_PROJECT_ID}/${FNAME}/download"
        UPLOADED="${UPLOADED},{\"name\":\"${FNAME}\",\"url\":\"${PKG_URL}/${FNAME}\"}"
      done

      # Strip leading comma and wrap in array.
      LINKS="[${UPLOADED#,}]"
      echo "ASSET_LINKS=${LINKS}" > asset_links.env
  artifacts:
    reports:
      dotenv: asset_links.env

# release-create: create the GitLab Release with links to all uploaded
# assets. This is the LAST step — nothing is user-visible until here.
# The Release body is extracted from the Release MR description that was
# merged, ensuring the changelog seen by users matches what was reviewed.
release-create:
  stage: publish
  image: alpine/curl:latest
  rules:
    - if: '$PIPELINE_KIND == "release"'
  needs:
    - job: upload-packages
      artifacts: true
    - job: tag-release
      artifacts: true
  script:
    - |
      apk add --no-cache curl jq > /dev/null 2>&1

      API="${CI_API_V4_URL}/projects/${CI_PROJECT_ID}"
      RELEASE_NAME="${RELEASE_TAG}"

      # Fetch the Release MR description (merged MR matching the release tag).
      CHANGELOG=$(curl -sf \
        --header "PRIVATE-TOKEN: ${KORYPH_RELEASE_TOKEN}" \
        "${API}/merge_requests?state=merged&labels=${RELEASE_MR_LABEL}&per_page=5" \
        | jq -r --arg tag "${RELEASE_TAG}" \
          '.[] | select(.title | test("^chore\\(release\\): " + $tag)) | .description // "" | .[0:4000]' \
        | head -1)

      [ -z "${CHANGELOG}" ] && CHANGELOG="Release ${RELEASE_TAG}"

      # Create the GitLab Release with all asset links.
      HTTP=$(curl -sf -w "%{http_code}" --request POST \
        --header "PRIVATE-TOKEN: ${KORYPH_RELEASE_TOKEN}" \
        --header "Content-Type: application/json" \
        --data "$(jq -n \
          --arg name "${RELEASE_NAME}" \
          --arg tag  "${RELEASE_TAG}" \
          --arg desc "${CHANGELOG}" \
          --argjson links "${ASSET_LINKS:-[]}" \
          '{name: $name, tag_name: $tag, description: $desc,
            assets: {links: $links}}')" \
        "${API}/releases" -o /dev/null)

      if [ "${HTTP}" = "200" ] || [ "${HTTP}" = "201" ]; then
        echo "release-create: ✓ GitLab Release ${RELEASE_TAG} created."
        echo "release-create: ${CI_SERVER_URL}/${CI_PROJECT_PATH}/-/releases/${RELEASE_TAG}"
      else
        echo "release-create: ERROR: GitLab API returned HTTP ${HTTP}"
        exit 1
      fi
  variables:
    RELEASE_MR_LABEL: koryph-release
