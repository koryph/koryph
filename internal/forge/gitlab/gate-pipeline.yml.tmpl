# Generated by `koryph ci setup --kind gate`. Do not edit by hand; re-run the
# command to update.
#
# Green gate pipeline — runs the project's gate command on every push and
# every merge request. Keeps the default branch and all open MRs green.
#
# Gate command: {{ .GateCmd }}
# Override with `koryph ci setup --kind gate --gate-cmd <cmd>` and re-run.
#
# This pipeline is toolchain-neutral: it checks out the repository and runs
# the gate command as given. Set the `image:` field to an image that has your
# toolchain installed, or configure a project-level default image in
# .gitlab-ci.yml if you include this snippet.

stages:
  - gate

gate:
  stage: gate
  rules:
    - if: '$CI_PIPELINE_SOURCE == "push"'
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
  script:
    - {{ .GateCmd }}
