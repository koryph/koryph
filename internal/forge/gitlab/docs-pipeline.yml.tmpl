# Generated by `koryph release setup`. Do not edit by hand; re-run the
# command to update.
#
# GitLab Pages docs-publish pipeline.
#
# Builds the MkDocs documentation and deploys it to GitLab Pages on every
# push to the default branch. Pages are published at:
#   https://<namespace>.gitlab.io/<project-path>/
#
# Prerequisites:
#   - mkdocs.yml at the repository root
#   - mkdocs-material (or the theme configured in mkdocs.yml) in requirements.txt
#     or installed in the CI image
#
# To serve locally:
#   pip install mkdocs-material
#   mkdocs serve

stages:
  - deploy

pages:
  stage: deploy
  image: python:3.12-slim
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
  script:
    - pip install --quiet mkdocs-material
    - mkdocs build --strict --site-dir public
  artifacts:
    paths:
      - public
    expire_in: 1 week
  environment:
    name: pages
    url: $CI_PAGES_URL
