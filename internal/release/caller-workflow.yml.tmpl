name: release
on:
  push:
    branches: [main]
permissions:
  contents: read
jobs:
  release:
    name: release
    # Caller must grant the superset of every permission the train's jobs
    # declare; actions:read is needed by its SLSA provenance job.
    permissions:
      contents: write
      id-token: write
      pull-requests: write
      actions: read
    uses: koryph/koryph/.github/workflows/release-train.yml@main
    with:
      release_type: "{{.Type}}"
{{- if .ExtraFiles}}
      extra_files: "{{join .ExtraFiles ","}}"
{{- end}}
{{- if .ArtifactsDir}}
      artifacts_dir: "{{.ArtifactsDir}}"
{{- end}}
      build_mode: "{{.BuildMode}}"
{{- if .GoreleaserVersion}}
      goreleaser_version: "{{.GoreleaserVersion}}"
{{- end}}
{{- if .BuildCommands}}
      build_commands: "{{join .BuildCommands "\\n"}}"
{{- end}}
      sbom: {{.SBOM}}
      provenance: {{.Provenance}}
    secrets: inherit
