# Generated by `koryph release setup`. Do not edit by hand; re-run the
# command to update. Pinned by koryph; unpin with care (supply-chain risk).
#
# EXPERIMENTAL: references koryph/koryph's release-train.yml reusable
# workflow. That workflow is planned for koryph-0vf.3; until it exists,
# this caller will fail at runtime but validates workflow syntax on push.
name: release
on:
  push:
    branches: [main]
permissions:
  contents: read
jobs:
  release:
    name: release
    permissions:
      contents: write
      id-token: write
      pull-requests: write
    uses: koryph/koryph/.github/workflows/release-train.yml@main
    with:
      release_type: "{{.Type}}"
{{- if .ExtraFiles}}
      extra_files: "{{join .ExtraFiles ","}}"
{{- end}}
{{- if .ArtifactsDir}}
      artifacts_dir: "{{.ArtifactsDir}}"
{{- end}}
      build_mode: "{{.BuildMode}}"
{{- if .GoreleaserVersion}}
      goreleaser_version: "{{.GoreleaserVersion}}"
{{- end}}
{{- if .BuildCommands}}
      build_commands: "{{join .BuildCommands "\\n"}}"
{{- end}}
      sbom: {{.SBOM}}
      provenance: {{.Provenance}}
    secrets: inherit
