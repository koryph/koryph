{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/agent-boundary-guard.sh\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/worktree-guard.sh\"",
            "type": "command"
          }
        ],
        "matcher": "Bash|Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/koryph-prime.sh\"  # replaces: bd prime --hook-json",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"${KORYPH_HOME:-$HOME/.koryph}/hooks/koryph-intent.sh\"",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(gh auth*)",
      "Bash(gh secret*)",
      "Bash(sudo*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}
