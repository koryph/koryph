# shellcheck shell=bash

# Load the pinned Nix dev shell (flake.nix) automatically when nix + nix-direnv
# are available. Falls through silently otherwise — run `nix develop` (or
# `make init`) by hand. See flake.nix for the pinned tool versions.
if command -v nix >/dev/null 2>&1 && declare -f use_flake >/dev/null 2>&1; then
  use flake
fi

# >>> claude-account (managed) >>>
# Claude Code account selection — committed; shared by all contributors.
# This project uses each contributor's PERSONAL (default) Claude account.
# See docs/ide-integration.md for the full two-layer isolation story.
# "Personal" == CLAUDE_CONFIG_DIR UNSET: Claude then uses its default profile
# (~/.claude.json) and the suffix-less "Claude Code-credentials" keychain entry.
# We unset here so an inherited WORK CLAUDE_CONFIG_DIR can't leak in via `code .`.
# Do NOT point this at ~/.claude: an explicit dir gets its own hashed keychain
# entry + $dir/.claude.json, which lands on a blank profile and forces re-login.
if [ -n "${CLAUDE_PERSONAL_CONFIG_DIR:-}" ]; then
  export CLAUDE_CONFIG_DIR="$CLAUDE_PERSONAL_CONFIG_DIR"
else
  unset CLAUDE_CONFIG_DIR
fi
source_env_if_exists ./.envrc.local
# <<< claude-account (managed) <<<
